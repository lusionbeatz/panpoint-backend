{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "outDir": "./dist",
    "rootDir": "./",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmitOnError": false,
    "resolveJsonModule": true
  },
  "include": ["src/**/*", "server.ts", "scripts/**/*"],
  "exclude": ["node_modules", "dist"]
}
